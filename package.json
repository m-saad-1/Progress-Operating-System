{
  "name": "personal-operating-system",
  "version": "1.0.0",
  "description": "A personal operating system built with Electron, React, and TypeScript.",
  "main": ".webpack/main",
  "config": {
    "forge": "./electron-forge.config.js"
  },
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "clean": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$targets=@('out','.webpack','dist','renderer/dist','renderer/node_modules/.vite','node_modules/.cache','renderer/node_modules/.cache'); foreach($t in $targets){ if(Test-Path $t){ Remove-Item -Recurse -Force $t } }\"",
    "clean:deps": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$targets=@('renderer/node_modules'); foreach($t in $targets){ if(Test-Path $t){ Remove-Item -Recurse -Force $t } }\"",
    "lint": "eslint --ext .ts,.tsx .",
    "type-check": "tsc --noEmit",
    "build:undo": "tsc -p undo/tsconfig.json",
    "build:sync": "tsc -p sync/tsconfig.json",
    "electron-rebuild": "electron-rebuild",
    "emailjs:test": "node scripts/emailjs-feedback-test.js",
    "feedback:test": "node scripts/feedback-smtp-test.js"
  },
  "keywords": [],
  "author": "Your Name",
  "license": "MIT",

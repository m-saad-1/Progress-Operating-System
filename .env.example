# ──────────────────────────────────────────────────────────────────────────────
# Feedback System Configuration
# ──────────────────────────────────────────────────────────────────────────────
# Feedback is sent from the Electron main process via Nodemailer (SMTP).
# No API keys are exposed to the renderer/frontend.
# Never commit your actual .env file with real credentials to version control.

# ─── Option 1: SMTP (recommended for desktop app) ───────────────────────────
# Works with Gmail, Outlook, SendGrid SMTP, Mailgun SMTP, etc.

# SMTP server host (e.g., smtp.gmail.com, smtp.office365.com)
FEEDBACK_SMTP_HOST=smtp.gmail.com

# SMTP port (587 for STARTTLS, 465 for SSL)
FEEDBACK_SMTP_PORT=587

# Set to "true" for port 465 (SSL), leave empty or "false" for 587 (STARTTLS)
FEEDBACK_SMTP_SECURE=false

# SMTP username (usually your email address)
FEEDBACK_SMTP_USER=your-email@gmail.com

# SMTP password (use App Password for Gmail with 2FA enabled)
# Gmail: https://myaccount.google.com/apppasswords
FEEDBACK_SMTP_PASS=your-app-password

# Email address that receives feedback submissions
FEEDBACK_TO_EMAIL=your-admin-email@example.com

# From address shown in the email
FEEDBACK_FROM_EMAIL=your-email@gmail.com

# From name shown in the email
FEEDBACK_FROM_NAME=PersonalOS Feedback

# ─── Option 2: Backend URL (for future SaaS integration) ────────────────────
# When set, feedback is POSTed to this URL instead of using SMTP directly.
# The backend should handle email delivery, storage, and notifications.
# FEEDBACK_BACKEND_URL=https://your-api.example.com/api/feedback
# FEEDBACK_BACKEND_API_KEY=your-backend-api-key
